generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  email     String?  @unique
  password  String?
  phone     String?
  name      String?
  isBlocked Boolean   @default(false)

  // Financial relations
  wallet       Wallet?
  transactions Transaction[]

  // Anti-cheat relations
  fraudLogs    FraudLog[]

  // Subscription relation
  subscription Subscription?

  // Weekly rewards relation
  weeklyRewards WeeklyReward[]

  // Field name matches requirement (`created_at`) while keeping the DB column
  // as the existing `createdAt` to avoid destructive migrations.
  created_at DateTime @default(now()) @map("createdAt")
  updatedAt DateTime @updatedAt

  contests    ContestParticipant[]
  responses   Response[]
  submissions Submission[]
}

model Wallet {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  balance   Float    @default(0)
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])
}

model Transaction {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String   // DEPOSIT, WITHDRAW, CONTEST_FEE
  amount    Float
  status    String   // PENDING, SUCCESS, FAILED
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}

model Contest {
  id                Int       @id @default(autoincrement())
  title             String
  entry_fee         Float
  prize_pool        Float
  start_time        DateTime
  total_questions   Int
  duration_minutes  Int?      // Optional contest-level timer for full contest duration
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  isPrizesDistributed   Boolean   @default(false)

  participants      ContestParticipant[]
  questions         Question[]
  responses         Response[]
  submissions       Submission[]
  fraudLogs         FraudLog[]
}

model ContestParticipant {
  id        Int      @id @default(autoincrement())
  userId    Int
  contestId Int
  joinedAt  DateTime @default(now())
  score     Int      @default(0)
  streak    Int      @default(0)

  user      User     @relation(fields: [userId], references: [id])
  contest   Contest  @relation(fields: [contestId], references: [id])

  @@unique([userId, contestId])
}

model Question {
  id          Int      @id @default(autoincrement())
  contest_id  Int
  question    String
  option_a    String
  option_b    String
  option_c    String
  option_d    String
  hint        String?
  explanation String?
  correct_ans String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contest     Contest  @relation(fields: [contest_id], references: [id])
  responses   Response[]
  answers     Answer[]
}

model Submission {
  id           Int      @id @default(autoincrement())
  user_id      Int
  contest_id   Int
  score        Int
  time_taken   Int
  submitted_at DateTime @default(now())

  user         User     @relation(fields: [user_id], references: [id])
  contest      Contest  @relation(fields: [contest_id], references: [id])

  answers      Answer[]
}

model Answer {
  id            Int    @id @default(autoincrement())
  submission_id Int
  question_id   Int
  selected_ans  String
  is_correct    Boolean

  submission Submission @relation(fields: [submission_id], references: [id])
  question   Question   @relation(fields: [question_id], references: [id])
}

model Response {
  id             Int      @id @default(autoincrement())
  userId         Int
  contestId      Int
  questionId     Int
  selectedOption String
  isCorrect      Boolean
  isTimeout      Boolean  @default(false)
  pointsEarned   Int      @default(0)
  responseTime   Float    @default(0) // time in seconds
  createdAt      DateTime @default(now())

  user           User     @relation(fields: [userId], references: [id])
  contest        Contest  @relation(fields: [contestId], references: [id])
  question       Question @relation(fields: [questionId], references: [id])

  @@unique([userId, contestId, questionId])
}

model FraudLog {
  id           Int      @id @default(autoincrement())
  userId       Int
  contestId    Int
  reason       String
  responseTime Float
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id])
  contest      Contest  @relation(fields: [contestId], references: [id])
}

model Subscription {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique // One subscription per user - enforced at DB level
  planType  String   // 'weekly' or 'monthly'
  startDate DateTime
  endDate   DateTime
  status    String   @default("active") // 'active' or 'expired'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])
}

model WeeklyReward {
  id             Int      @id @default(autoincrement())
  userId         Int
  weekStart      DateTime
  weekEnd        DateTime
  rank           Int
  totalScore     Int
  contestsPlayed Int
  averageScore   Int
  rewardAmount   Float
  createdAt      DateTime @default(now())

  user           User     @relation(fields: [userId], references: [id])

  @@unique([userId, weekStart]) // One reward per user per week
}
