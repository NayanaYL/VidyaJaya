NODE_ENV=development
PORT=4000

# PostgreSQL database connection string for Prisma.
# In production, replace with the managed DB URL from your provider.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vidyajaya?schema=public"

# Redis connection string for caching, session state, and leaderboard sync.
REDIS_URL="redis://localhost:6379"

JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="1h"

LOG_LEVEL=info

OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5

# Production notes:
# - Set NODE_ENV=production for production mode.
# - Keep JWT_SECRET secret and never commit it to version control.
# - Use a managed PostgreSQL and Redis service for production workloads.
