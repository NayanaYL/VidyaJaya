NODE_ENV=development
PORT=4000

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vidyajaya?schema=public"

JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="1h"

LOG_LEVEL=info

OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5

# Optional: enable Redis-backed OTP storage (recommended for production).
# If not set, OTP will be stored in-memory (works for local development).
# REDIS_URL="redis://localhost:6379"
